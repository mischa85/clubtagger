# Clubtagger nginx configuration example
# Copy to /etc/nginx/sites-available/clubtagger and symlink to sites-enabled
#
# Generate self-signed cert:
#   mkdir -p /etc/nginx/ssl
#   openssl req -x509 -nodes -days 3650 -newkey rsa:2048 \
#     -keyout /etc/nginx/ssl/clubtagger.key \
#     -out /etc/nginx/ssl/clubtagger.crt \
#     -subj "/CN=192.168.178.100" \
#     -addext "subjectAltName=IP:192.168.178.100"
#
# Generate password file:
#   htpasswd -Bc /etc/nginx/clubtagger.htpasswd <user>

upstream clubtagger {
    server unix:/run/clubtagger.sock;
}

# Redirect HTTP to HTTPS
server {
    listen 80;
    server_name _;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name _;

    ssl_certificate /etc/nginx/ssl/clubtagger.crt;
    ssl_certificate_key /etc/nginx/ssl/clubtagger.key;

    # Basic auth
    auth_basic "Clubtagger";
    auth_basic_user_file /etc/nginx/clubtagger.htpasswd;

    # Static files (HTML, JS, CSS)
    location / {
        root /var/www/clubtagger;
        index index.html;
        try_files $uri $uri/ =404;
    }

    # WebSocket proxy to clubtagger Unix socket
    location /sse {
        proxy_pass http://clubtagger;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Disable buffering for real-time data
        proxy_buffering off;
        proxy_cache off;

        # Long timeout for WebSocket connections
        proxy_read_timeout 24h;
        proxy_send_timeout 24h;
    }
}
